-- Input: keybind capture + toggle hotkey
UserInputService.InputBegan:Connect(function(input, gpe)
	if listeningForKey then
		if input.UserInputType == Enum.UserInputType.Keyboard then
			toggleKey = input.KeyCode
			KeyBind.Text = input.KeyCode.Name:sub(1, 4)
			KeyBind.TextColor3 = Color3.fromRGB(210, 210, 210)
			KeyStroke.Color = Color3.fromRGB(90, 90, 90)
			listeningForKey = false
		end
		return
	end
	if input.KeyCode == toggleKey and not gpe then
		setLagger(not laggerEnabled)
	end
end)

