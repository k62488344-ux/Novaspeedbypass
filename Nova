-- SLIDER FUNCTIONS
local function updateLagSlider(x)
	local barPos = lagBar.AbsolutePosition.X
	local barSize = lagBar.AbsoluteSize.X
	local rel = math.clamp((x - barPos) / barSize, 0, 1)
	
	lagFill.Size = UDim2.fromScale(rel, 1)
	lagKnob.Position = UDim2.new(rel, 0, 0.5, 0)
	lagAmount = rel
	lagLabel.Text = "Lag Intensity: " .. math.floor(rel * 100) .. "%"
end

local function updateSpeedSlider(x)
	local barPos = speedBar.AbsolutePosition.X
	local barSize = speedBar.AbsoluteSize.X
	local rel = math.clamp((x - barPos) / barSize, 0, 1)
	
	speedFill.Size = UDim2.fromScale(rel, 1)
	speedKnob.Position = UDim2.new(rel, 0, 0.5, 0)
	speedAmount = math.floor(16 + rel * 84)
	speedLabel.Text = "Speed: " .. speedAmount
end

-- DRAG SYSTEM
local draggingSlider = nil
local draggingUI = false
local dragStart, startPos

-- Slider dragging
lagBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingSlider = "lag"
		updateLagSlider(input.Position.X)
	end
end)

lagKnob.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingSlider = "lag"
	end
end)

speedBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingSlider = "speed"
		updateSpeedSlider(input.Position.X)
	end
end)

speedKnob.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingSlider = "speed"
	end
end)

-- UI Dragging (only on title bar)
titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingUI = true
		dragStart = input.Position
		startPos = main.Position
	end
end)

UIS.InputChanged:Connect(function(input)
	if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
		if draggingSlider == "lag" then
			updateLagSlider(input.Position.X)
		elseif draggingSlider == "speed" then
			updateSpeedSlider(input.Position.X)
		end
	end
	
	if draggingUI and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		main.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingSlider = nil
		draggingUI = false
	end
end)

