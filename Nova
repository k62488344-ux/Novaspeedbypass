-- Slider input handling
local draggingSlider = false
local sliderMin, sliderMax = 1, 500

local function updateSlider(value)
	value = math.clamp(value, sliderMin, sliderMax)
	LAGGER_CONFIG.TableIncrease = math.floor(value)
	SliderValue.Text = tostring(LAGGER_CONFIG.TableIncrease)
	
	local percent = (LAGGER_CONFIG.TableIncrease - sliderMin) / (sliderMax - sliderMin)
	SliderFill.Size = UDim2.new(percent, 0, 1, 0)
	SliderKnob.Position = UDim2.new(percent, -7, 0.5, -7)
end

SliderKnob.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingSlider = true
	end
end)

SliderTrack.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		local trackPos = SliderTrack.AbsolutePosition.X
		local trackWidth = SliderTrack.AbsoluteSize.X
		local clickX = math.clamp(input.Position.X - trackPos, 0, trackWidth)
		local percent = clickX / trackWidth
		local newValue = sliderMin + (sliderMax - sliderMin) * percent
		updateSlider(newValue)
		draggingSlider = true
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingSlider = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local trackPos = SliderTrack.AbsolutePosition.X
		local trackWidth = SliderTrack.AbsoluteSize.X
		local mouseX = math.clamp(input.Position.X - trackPos, 0, trackWidth)
		local percent = mouseX / trackWidth
		local newValue = sliderMin + (sliderMax - sliderMin) * percent
		updateSlider(newValue)
	end
end)

-- setLagger
local function setLagger(state)
	laggerEnabled = state
	local tw = TweenInfo.new(0.18, Enum.EasingStyle.Quad)
	if laggerEnabled then
		TweenService:Create(ToggleBg, tw, {BackgroundColor3 = Color3.fromRGB(240, 240, 240)}):Play()
		TweenService:Create(ToggleDot, tw, {
			Position = UDim2.new(0, 24, 0.5, -8),
			BackgroundColor3 = Color3.fromRGB(10, 10, 10)
		}):Play()
		startLagger()
	else
		TweenService:Create(ToggleBg, tw, {BackgroundColor3 = Color3.fromRGB(60, 60, 60)}):Play()
		TweenService:Create(ToggleDot, tw, {
			Position = UDim2.new(0, 4, 0.5, -8),
			BackgroundColor3 = Color3.fromRGB(150, 150, 150)
		}):Play()
		stopLaggerLoop()
	end
end

